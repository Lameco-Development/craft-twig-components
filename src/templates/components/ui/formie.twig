{# Theme #}
{% set theme = theme is defined and theme is not empty
  ? theme|json_decode
  : _globals.get('formie.theme')
%}

{# Component Variables #}
{% set form = form ?? null %}

{# Component #}
{% if form is not empty %}
  {{ craft.formie.renderForm(form, theme) }}

  {# prettier-ignore-start #}
  {% js %}
  // Register once: onFormieInit fires for every form on the page, so binding the
  // document listener per-component would double-bind handlers (and double-push)
  // when a page holds more than one form.
  if (!window.lamecoFormieTrackingBound) {
    window.lamecoFormieTrackingBound = true;

    document.addEventListener("onFormieInit", (event) => {
      let Formie = event.detail.formie;
      let $form = event.detail.$form;

      // Required so Formie forms keep working on Blitz-cached pages (CSRF token refresh).
      Formie.refreshForCache(event.detail.formId);

      // GTM: these forms submit via Page Reload and redirect to a (cached) thank-you
      // page, so there is no client-side "after submit" event to hook. The last
      // client-side signal is validation passing right before the native submit.
      // Gated on dataLayer existing, so it stays dormant until GTM is installed.
      // NOTE: on multi-page forms this fires once per page — use the server-side
      // push on the thank-you page for an accurate per-conversion signal.
      $form.addEventListener("onAfterFormieValidate", (e) => {
        if (typeof window.dataLayer === "undefined") {
          return;
        }

        window.dataLayer.push({
          "event": "formSubmitted",
          "formHandle": event.detail.form.config.formHandle,
          "formId": event.detail.formId,
        });
      });
    });
  }
  {% endjs %}
  {# prettier-ignore-end #}
{% endif %}
