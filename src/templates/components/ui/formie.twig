{# Theme #}
{% set theme = theme is defined and theme is not empty
  ? theme|json_decode
  : _globals.get('formie.theme')
%}

{# Component Variables #}
{% set form = form ?? null %}

{# Component #}
{% if form is not empty %}
  {{ craft.formie.renderForm(form, theme) }}

  {# prettier-ignore-start #}
  {% js %}
  // Register once: onFormieInit fires for every form on the page, so binding the
  // document listener per-component would double-bind handlers (and double-push)
  // when a page holds more than one form.
  if (!window.lamecoFormieTrackingBound) {
    window.lamecoFormieTrackingBound = true;

    document.addEventListener("onFormieInit", (event) => {
      let Formie = event.detail.formie;
      let $form = event.detail.$form;
      let config = event.detail.form.config;

      // Required so Formie forms keep working on Blitz-cached pages (CSRF token refresh).
      Formie.refreshForCache(event.detail.formId);

      // GTM: push `formSubmitted` to the dataLayer, gated on dataLayer existing so it
      // stays dormant until GTM is installed. The right hook depends on submit method:
      let push = () => {
        if (typeof window.dataLayer === "undefined") {
          return;
        }

        window.dataLayer.push({
          "event": "formSubmitted",
          "formHandle": config.formHandle,
          "formId": event.detail.formId,
        });
      };

      if (config.settings.submitMethod === "ajax") {
        // Ajax: onAfterFormieSubmit fires on confirmed success. nextPageId guards
        // multi-page forms so only the final page pushes.
        $form.addEventListener("onAfterFormieSubmit", (e) => {
          if (e.detail.nextPageId) {
            return;
          }

          push();
        });
      } else {
        // Page Reload: the page navigates away on submit, so the last client-side
        // signal is validation passing (≈ about-to-submit). Fires once per page on
        // multi-page forms — use the thanks-page push for accurate conversions there.
        $form.addEventListener("onAfterFormieValidate", () => {
          push();
        });
      }
    });
  }
  {% endjs %}
  {# prettier-ignore-end #}
{% endif %}
